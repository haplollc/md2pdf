<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		iOS is always sandboxed, so the macOS `com.apple.security.*`
		sandbox keys don't apply here. File access is granted per-document
		by the system file picker / "open in place", and network access
		needs no entitlement. This file is intentionally empty.
	-->
</dict>
</plist>
